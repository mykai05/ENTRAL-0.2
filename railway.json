{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile && pnpm prisma:generate && pnpm --filter @entral/backend build"
  },
  "deploy": {
    "preDeployCommand": "pnpm prisma:deploy",
    "startCommand": "pnpm --filter @entral/backend start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
