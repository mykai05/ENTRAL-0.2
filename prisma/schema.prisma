generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         String       @default("USER")
  emailVerifiedAt DateTime?
  lastDashboardSeenAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  TeamMember[]
  tasksCreated Task[]       @relation("TaskCreatedBy")
  tasksAssigned Task[]      @relation("TaskAssignedTo")
  conversations Conversation[]
  aiUsageEvents AiUsageEvent[]
  automationJobs AutomationJob[]
  agents      Agent[]
  agentTasks  AgentTask[]
  agentSchedules AgentSchedule[]
  merchStores ClientMerchStore[]
  revenueOpportunities RevenueOpportunity[]
  revenuePerformanceSnapshots RevenuePerformanceSnapshot[]
  revenueAssetControlRecords RevenueAssetControlRecord[]
  financialSplitPolicies FinancialSplitPolicy[]
  financialLedgerEntries FinancialLedgerEntry[]
  financialPayoutIntents FinancialPayoutIntent[]
  financialScalingBudgetPackets FinancialScalingBudgetPacket[]
  financialScalingSpendPackets FinancialScalingSpendPacket[]
  financialScalingExecutionEntries FinancialScalingExecutionEntry[]
  financialBudgetReleasePackets FinancialBudgetReleasePacket[]
  financialReconciliationReports FinancialReconciliationReport[]
  facelessContentBriefs FacelessContentBrief[]
  facelessContentPerformanceSnapshots FacelessContentPerformanceSnapshot[]
  portfolioCommandActions PortfolioCommandAction[]
  revenueLaunchHandoffPackets RevenueLaunchHandoffPacket[]
  revenueSignalConnectorApprovals RevenueSignalConnectorApproval[]
  revenueSignalImportJobs RevenueSignalImportJob[]
  commandSnapshot CommandOSSnapshot?
  commandReports CommandOSReport[]
  policiesCreated Policy[]      @relation("PolicyCreatedBy")
  auditLogs   AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  growthApprovalPackets GrowthApprovalPacket[] @relation("GrowthApprovalOwner")
  growthApprovalsReviewed GrowthApprovalPacket[] @relation("GrowthApprovalReviewer")

  @@index([email])
  @@index([emailVerifiedAt])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

enum MerchStorePlatform {
  ETSY    @map("Etsy")
  SHOPIFY @map("Shopify")
  OTHER   @map("Other")
}

enum MerchPodProvider {
  PRINTIFY @map("Printify")
  PRINTFUL @map("Printful")
  OTHER    @map("Other")
}

enum MerchApprovalStatus {
  NOT_STARTED       @map("Not Started")
  RESEARCH_APPROVED @map("Research Approved")
  DESIGNS_PENDING   @map("Designs Pending")
  DESIGNS_APPROVED  @map("Designs Approved")
  LISTINGS_APPROVED @map("Listings Approved")
  LAUNCH_APPROVED   @map("Launch Approved")
}

enum MerchLaunchStatus {
  LEAD              @map("Lead")
  DISCOVERY         @map("Discovery")
  RESEARCHING       @map("Researching")
  DESIGNING         @map("Designing")
  AWAITING_APPROVAL @map("Awaiting Approval")
  BUILDING_STORE    @map("Building Store")
  LAUNCHED          @map("Launched")
  OPTIMIZING        @map("Optimizing")
  PAUSED            @map("Paused")
  ARCHIVED          @map("Archived")
}

model ClientMerchStore {
  id              String               @id @default(cuid())
  userId          String
  clientName      String
  businessName    String
  contactName     String
  email           String
  phone           String?
  industry        String
  audience        String
  brandStyle      String
  storePlatform   MerchStorePlatform   @default(ETSY)
  podProvider     MerchPodProvider     @default(PRINTIFY)
  productTypes    String[]             @default([])
  designCount     Int                  @default(0)
  setupFee        Decimal              @default(0) @db.Decimal(12, 2)
  monthlyFee      Decimal              @default(0) @db.Decimal(12, 2)
  profitShare     Decimal              @default(0) @db.Decimal(5, 2)
  approvalStatus  MerchApprovalStatus  @default(NOT_STARTED)
  launchStatus    MerchLaunchStatus    @default(LEAD)
  revenue         Decimal              @default(0) @db.Decimal(12, 2)
  estimatedProfit Decimal              @default(0) @db.Decimal(12, 2)
  notes           String?
  commandMarshalId   String?
  commandMarshalName String?
  commandGeneralId   String?
  commandGeneralName String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  products        PodProduct[]
  revenueOpportunities RevenueOpportunity[]
  growthApprovalPackets GrowthApprovalPacket[]
  revenueLaunchHandoffPackets RevenueLaunchHandoffPacket[]
  revenueAssetControlRecords RevenueAssetControlRecord[]
  performanceSnapshots RevenuePerformanceSnapshot[]
  financialScalingExecutionEntries FinancialScalingExecutionEntry[]
  financialLedgerEntries FinancialLedgerEntry[]
  facelessContentBriefs FacelessContentBrief[]
  facelessContentPerformanceSnapshots FacelessContentPerformanceSnapshot[]

  @@index([userId, launchStatus])
  @@index([userId, approvalStatus])
  @@index([userId, createdAt])
  @@index([userId, commandMarshalId])
  @@index([userId, commandGeneralId])
  @@index([email])
}

model RevenueOpportunity {
  id                String            @id @default(cuid())
  userId            String
  storeId           String?
  sourceKey         String
  idea              String
  businessName      String
  status            String            @default("active")
  planJson          String
  totalsJson        String
  externalExecution Boolean           @default(false)
  providerContacted Boolean           @default(false)
  auditLogId        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  store             ClientMerchStore? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceKey])
  @@index([userId, status])
  @@index([storeId])
  @@index([createdAt])
}

model GrowthApprovalPacket {
  id                String           @id @default(cuid())
  userId            String
  storeId           String
  status            String           @default("pending")
  mode              String           @default("Mock Mode")
  packetJson        String
  scheduledFor      DateTime?
  requestAuditLogId String?
  reviewAuditLogId  String?
  reviewedAt        DateTime?
  reviewedById      String?
  reviewNote        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation("GrowthApprovalOwner", fields: [userId], references: [id], onDelete: Cascade)
  store             ClientMerchStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reviewedBy        User?            @relation("GrowthApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([storeId, status])
  @@index([scheduledFor])
  @@index([createdAt])
}

enum PodProductStatus {
  IDEA              @map("Idea")
  PROMPT_READY      @map("Prompt Ready")
  DESIGNED          @map("Designed")
  MOCKUP_CREATED    @map("Mockup Created")
  LISTING_DRAFTED   @map("Listing Drafted")
  COMPLIANCE_REVIEW @map("Compliance Review")
  AWAITING_APPROVAL @map("Awaiting Approval")
  APPROVED          @map("Approved")
  PUBLISHED         @map("Published")
  NEEDS_REVISION    @map("Needs Revision")
  REJECTED          @map("Rejected")
  ARCHIVED          @map("Archived")
}

model PodProduct {
  id                                  String           @id @default(cuid())
  storeId                             String
  productName                         String
  productType                         String
  targetAudience                      String
  designTheme                         String
  designConcept                       String
  designPrompt                        String
  typographyDirection                 String
  colorDirection                      String
  mockupNotes                         String?
  supplierCost                        Decimal          @default(0) @db.Decimal(12, 2)
  shippingCost                        Decimal          @default(0) @db.Decimal(12, 2)
  retailPrice                         Decimal          @default(0) @db.Decimal(12, 2)
  estimatedPlatformFees               Decimal          @default(0) @db.Decimal(12, 2)
  estimatedProfit                     Decimal          @default(0) @db.Decimal(12, 2)
  profitMargin                        Decimal          @default(0) @db.Decimal(7, 2)
  listingTitle                        String?
  listingDescription                  String?
  tags                                String[]         @default([])
  complianceNotes                     String?
  aiDisclosureNeeded                  Boolean          @default(false)
  productionPartnerDisclosureNeeded   Boolean          @default(false)
  status                              PodProductStatus @default(IDEA)
  commandMarshalId                    String?
  commandMarshalName                  String?
  commandGeneralId                    String?
  commandGeneralName                  String?
  commandCommanderId                  String?
  commandCommanderName                String?
  commandSoldierId                    String?
  commandSoldierName                  String?
  createdAt                           DateTime         @default(now())
  updatedAt                           DateTime         @updatedAt
  store                               ClientMerchStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  performanceSnapshots                RevenuePerformanceSnapshot[]
  revenueAssetControlRecords          RevenueAssetControlRecord[]
  financialScalingExecutionEntries    FinancialScalingExecutionEntry[]
  financialLedgerEntries              FinancialLedgerEntry[]
  facelessContentBriefs                FacelessContentBrief[]
  facelessContentPerformanceSnapshots  FacelessContentPerformanceSnapshot[]

  @@index([storeId, status])
  @@index([storeId, createdAt])
  @@index([commandMarshalId])
  @@index([commandGeneralId])
  @@index([productType])
}

model RevenuePerformanceSnapshot {
  id                  String           @id @default(cuid())
  userId              String
  storeId             String
  productId           String?
  source              String           @default("manual")
  periodStart         DateTime
  periodEnd           DateTime
  impressions         Int              @default(0)
  visits              Int              @default(0)
  unitsSold           Int              @default(0)
  grossRevenue        Decimal          @default(0) @db.Decimal(12, 2)
  refunds             Decimal          @default(0) @db.Decimal(12, 2)
  discounts           Decimal          @default(0) @db.Decimal(12, 2)
  platformFees        Decimal          @default(0) @db.Decimal(12, 2)
  productionCost      Decimal          @default(0) @db.Decimal(12, 2)
  shippingCost        Decimal          @default(0) @db.Decimal(12, 2)
  adSpend             Decimal          @default(0) @db.Decimal(12, 2)
  digitalDeliveryCost Decimal          @default(0) @db.Decimal(12, 2)
  netProfit           Decimal          @default(0) @db.Decimal(12, 2)
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  store               ClientMerchStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product             PodProduct?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  financialLedgerEntry FinancialLedgerEntry?

  @@index([userId, periodEnd])
  @@index([storeId, periodEnd])
  @@index([productId, periodEnd])
  @@index([source, periodEnd])
}

model RevenueAssetControlRecord {
  id                    String   @id @default(cuid())
  userId                String
  storeId               String?
  productId             String?
  assetId               String
  assetName             String
  assetType             String
  storeName             String
  requestedAction       String
  scoringRecommendation String
  finalRank             Int      @default(0)
  economicsScore        Int      @default(0)
  readinessScore        Int      @default(0)
  riskPenalty           Int      @default(0)
  velocity              Int      @default(0)
  scoreBand             String
  riskLevel             String
  reason                String
  nextInternalState     String?
  fromStatus            String?
  toStatus              String?
  statusChangeRequired  Boolean  @default(false)
  auditOnly             Boolean  @default(true)
  override              Boolean  @default(false)
  warningsJson          String
  controlJson           String
  externalExecution     Boolean  @default(false)
  providerContacted     Boolean  @default(false)
  auditLogId            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store                 ClientMerchStore? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  product               PodProduct?       @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, requestedAction])
  @@index([userId, scoringRecommendation])
  @@index([userId, assetType, assetId])
  @@index([userId, storeId])
  @@index([productId])
  @@index([auditLogId])
  @@index([createdAt])
}

model FinancialSplitPolicy {
  id                    String                  @id @default(cuid())
  userId                String
  name                  String                  @default("Default Financial Orchestrator Split")
  scalingPercent        Decimal                 @default(25) @db.Decimal(5, 2)
  personalPercent       Decimal                 @default(50) @db.Decimal(5, 2)
  bufferPercent         Decimal                 @default(25) @db.Decimal(5, 2)
  minPayoutIntentAmount Decimal                 @default(25) @db.Decimal(12, 2)
  reserveFloorAmount    Decimal                 @default(0) @db.Decimal(12, 2)
  currency              String                  @default("USD")
  status                String                  @default("active")
  externalExecution     Boolean                 @default(false)
  metadataJson          String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutIntents         FinancialPayoutIntent[]
  scalingBudgetPackets  FinancialScalingBudgetPacket[]

  @@index([userId, status])
  @@index([userId, createdAt])
}

model FinancialLedgerEntry {
  id                           String                     @id @default(cuid())
  userId                       String
  storeId                      String
  productId                    String?
  revenuePerformanceSnapshotId String                     @unique
  source                       String
  periodStart                  DateTime
  periodEnd                    DateTime
  grossRevenue                 Decimal                    @default(0) @db.Decimal(12, 2)
  netProfit                    Decimal                    @default(0) @db.Decimal(12, 2)
  allocatableProfit            Decimal                    @default(0) @db.Decimal(12, 2)
  scalingAmount                Decimal                    @default(0) @db.Decimal(12, 2)
  personalAmount               Decimal                    @default(0) @db.Decimal(12, 2)
  bufferAmount                 Decimal                    @default(0) @db.Decimal(12, 2)
  currency                     String                     @default("USD")
  status                       String                     @default("recorded")
  externalExecution            Boolean                    @default(false)
  metadataJson                 String?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  user                         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store                        ClientMerchStore           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product                      PodProduct?                @relation(fields: [productId], references: [id], onDelete: SetNull)
  revenuePerformanceSnapshot   RevenuePerformanceSnapshot @relation(fields: [revenuePerformanceSnapshotId], references: [id], onDelete: Cascade)

  @@index([userId, periodEnd])
  @@index([storeId, periodEnd])
  @@index([productId, periodEnd])
  @@index([source, periodEnd])
}

model FinancialPayoutIntent {
  id                String                @id @default(cuid())
  userId            String
  splitPolicyId     String?
  category          String
  destinationType   String
  provider          String                @default("Stripe Treasury + Connect")
  amount            Decimal               @default(0) @db.Decimal(12, 2)
  currency          String                @default("USD")
  status            String                @default("approval_required")
  externalExecution Boolean               @default(false)
  approvalRequired  Boolean               @default(true)
  dedupeKey         String                @unique
  metadataJson      String?
  auditLogId        String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitPolicy       FinancialSplitPolicy? @relation(fields: [splitPolicyId], references: [id], onDelete: SetNull)
  budgetReleasePacket FinancialBudgetReleasePacket?

  @@index([userId, status])
  @@index([userId, category])
  @@index([createdAt])
}

model FinancialBudgetReleasePacket {
  id                String                @id @default(cuid())
  userId            String
  payoutIntentId    String                @unique
  category          String
  destinationType   String
  amount            Decimal               @default(0) @db.Decimal(12, 2)
  maxReleaseAmount  Decimal               @default(0) @db.Decimal(12, 2)
  currency          String                @default("USD")
  approvalState     String                @default("approval_required")
  releaseState      String                @default("locked_review")
  purpose           String
  controlsJson      String
  blockedActionsJson String
  externalExecution Boolean               @default(false)
  auditLogId        String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutIntent      FinancialPayoutIntent @relation(fields: [payoutIntentId], references: [id], onDelete: Cascade)

  @@index([userId, releaseState])
  @@index([userId, category])
  @@index([createdAt])
}

model FinancialScalingBudgetPacket {
  id                    String                @id @default(cuid())
  userId                String
  splitPolicyId         String?
  dedupeKey             String                @unique
  assetId               String
  assetName             String
  assetType             String
  storeId               String
  storeName             String
  amount                Decimal               @default(0) @db.Decimal(12, 2)
  maxPerAssetAmount     Decimal               @default(0) @db.Decimal(12, 2)
  retainedScalingCapital Decimal              @default(0) @db.Decimal(12, 2)
  totalScalingCapital   Decimal               @default(0) @db.Decimal(12, 2)
  profitVelocity        Decimal               @default(0) @db.Decimal(12, 2)
  score                 Int                   @default(0)
  scoreBand             String
  confidence            Int                   @default(0)
  priority              Int                   @default(0)
  status                String                @default("approval_required")
  approvalRequired      Boolean               @default(true)
  externalExecution     Boolean               @default(false)
  providerContacted     Boolean               @default(false)
  reason                String
  approvalGateJson      String
  blockedActionsJson    String
  metadataJson          String?
  auditLogId            String?
  reviewedAt            DateTime?
  reviewedById          String?
  reviewNote            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitPolicy           FinancialSplitPolicy? @relation(fields: [splitPolicyId], references: [id], onDelete: SetNull)
  spendPackets          FinancialScalingSpendPacket[]

  @@index([userId, status])
  @@index([userId, assetType, assetId])
  @@index([userId, storeId])
  @@index([createdAt])
}

model FinancialScalingSpendPacket {
  id                    String                       @id @default(cuid())
  userId                String
  scalingBudgetPacketId String
  dedupeKey             String                       @unique
  category              String
  assetId               String
  assetName             String
  assetType             String
  storeId               String
  storeName             String
  amount                Decimal                      @default(0) @db.Decimal(12, 2)
  maxSpendAmount        Decimal                      @default(0) @db.Decimal(12, 2)
  currency              String                       @default("USD")
  approvalState         String                       @default("approval_required")
  releaseState          String                       @default("locked_review")
  purpose               String
  controlsJson          String
  blockedActionsJson    String
  score                 Int                          @default(0)
  priority              Int                          @default(0)
  externalExecution     Boolean                      @default(false)
  providerContacted     Boolean                      @default(false)
  auditLogId            String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scalingBudgetPacket   FinancialScalingBudgetPacket @relation(fields: [scalingBudgetPacketId], references: [id], onDelete: Cascade)
  executionEntries      FinancialScalingExecutionEntry[]

  @@index([userId, releaseState])
  @@index([userId, category])
  @@index([userId, assetType, assetId])
  @@index([userId, storeId])
  @@index([createdAt])
}

model FinancialScalingExecutionEntry {
  id                    String                       @id @default(cuid())
  userId                String
  scalingSpendPacketId  String
  storeId               String
  productId             String?
  assetId               String
  assetName             String
  assetType             String
  storeName             String
  category              String
  amountSpent           Decimal                      @default(0) @db.Decimal(12, 2)
  grossRevenue          Decimal                      @default(0) @db.Decimal(12, 2)
  netProfit             Decimal                      @default(0) @db.Decimal(12, 2)
  unitsSold             Int                          @default(0)
  visits                Int                          @default(0)
  periodStart           DateTime
  periodEnd             DateTime
  outcome               String                       @default("watch")
  source                String                       @default("manual")
  notes                 String?
  externalExecution     Boolean                      @default(false)
  providerContacted     Boolean                      @default(false)
  auditLogId            String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scalingSpendPacket    FinancialScalingSpendPacket  @relation(fields: [scalingSpendPacketId], references: [id], onDelete: Cascade)
  store                 ClientMerchStore             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product               PodProduct?                  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, outcome])
  @@index([userId, category])
  @@index([userId, assetType, assetId])
  @@index([userId, storeId])
  @@index([scalingSpendPacketId])
  @@index([createdAt])
}

model FinancialReconciliationReport {
  id                String   @id @default(cuid())
  userId            String
  source            String   @default("payout_review")
  status            String   @default("recorded")
  totalAmount       Decimal  @default(0) @db.Decimal(12, 2)
  approvedAmount    Decimal  @default(0) @db.Decimal(12, 2)
  pendingAmount     Decimal  @default(0) @db.Decimal(12, 2)
  rejectedAmount    Decimal  @default(0) @db.Decimal(12, 2)
  variance          Decimal  @default(0) @db.Decimal(12, 2)
  reportJson        String
  externalExecution Boolean  @default(false)
  auditLogId        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([source, createdAt])
}

model FacelessContentBrief {
  id                    String           @id @default(cuid())
  userId                String
  storeId               String
  productId             String?
  dedupeKey             String           @unique
  title                 String
  status                String           @default("draft_queued")
  priority              Int              @default(0)
  targetChannelsJson    String
  conceptJson           String
  scriptJson            String
  storyboardJson        String
  voiceoverJson         String
  videoJson             String
  uploadPackageJson     String
  providerReadinessJson String
  blockedActionsJson    String
  externalExecution     Boolean          @default(false)
  auditLogId            String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  store                 ClientMerchStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product               PodProduct?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  performanceSnapshots  FacelessContentPerformanceSnapshot[]

  @@index([userId, status])
  @@index([storeId, createdAt])
  @@index([productId])
  @@index([createdAt])
}

model FacelessContentPerformanceSnapshot {
  id                String                 @id @default(cuid())
  userId            String
  contentBriefId    String?
  storeId           String?
  productId         String?
  source            String                 @default("manual")
  channel           String
  periodStart       DateTime
  periodEnd         DateTime
  views             Int                    @default(0)
  likes             Int                    @default(0)
  comments          Int                    @default(0)
  shares            Int                    @default(0)
  saves             Int                    @default(0)
  clicks            Int                    @default(0)
  conversions       Int                    @default(0)
  watchSeconds      Int                    @default(0)
  revenue           Decimal                @default(0) @db.Decimal(12, 2)
  cost              Decimal                @default(0) @db.Decimal(12, 2)
  externalExecution Boolean                @default(false)
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentBrief      FacelessContentBrief?  @relation(fields: [contentBriefId], references: [id], onDelete: SetNull)
  store             ClientMerchStore?      @relation(fields: [storeId], references: [id], onDelete: SetNull)
  product           PodProduct?            @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, periodEnd])
  @@index([contentBriefId, periodEnd])
  @@index([storeId, periodEnd])
  @@index([productId, periodEnd])
  @@index([channel, periodEnd])
  @@index([source, periodEnd])
}

model PortfolioCommandAction {
  id                String   @id @default(cuid())
  userId            String
  targetType        String
  targetId          String
  targetName        String
  action            String
  sourceModule      String
  status            String   @default("queued")
  priority          Int      @default(0)
  riskLevel         String   @default("low")
  reason            String
  recommendedStatus String?
  commandHash       String
  controlJson       String
  externalExecution Boolean  @default(false)
  providerContacted Boolean  @default(false)
  auditLogId        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, targetType, targetId])
  @@index([userId, action])
  @@index([createdAt])
}

model RevenueLaunchHandoffPacket {
  id                      String           @id @default(cuid())
  userId                  String
  storeId                 String
  approvedPacketId        String?
  dedupeKey               String           @unique
  storeName               String
  status                  String           @default("queued_review")
  action                  String
  riskLevel               String           @default("low")
  connectorStatus         String?
  connectorReadinessScore Int              @default(0)
  launchReadinessScore    Int              @default(0)
  providerReadinessScore  Int              @default(0)
  manifestCount           Int              @default(0)
  artifactSlotCount       Int              @default(0)
  credentialScopesJson    String
  providersJson           String
  blockersJson            String
  blockedActionsJson      String
  bundleJson              String?
  summary                 String
  externalExecution       Boolean          @default(false)
  providerContacted       Boolean          @default(false)
  auditLogId              String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  user                    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  store                   ClientMerchStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([storeId, status])
  @@index([userId, action])
  @@index([createdAt])
}

model RevenueSignalConnectorApproval {
  id                    String   @id @default(cuid())
  userId                String
  dedupeKey             String
  manifestId            String
  lane                  String
  provider              String
  providerName          String
  status                String   @default("pending_review")
  riskLevel             String   @default("low")
  readinessScore        Int      @default(0)
  transformTarget       String
  storeId               String?
  storeName             String?
  productId             String?
  contentBriefId        String?
  manifestJson          String
  samplePayloadJson     String?
  signalPreviewJson     String
  blockedActionsJson    String
  credentialEnvVarsJson String
  readOnlyScopesJson    String
  endpointTemplatesJson String
  externalExecution     Boolean  @default(false)
  providerContacted     Boolean  @default(false)
  requestAuditLogId     String?
  reviewAuditLogId      String?
  reviewedAt            DateTime?
  reviewedById          String?
  reviewNote            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  importJobs            RevenueSignalImportJob[]

  @@unique([userId, dedupeKey])
  @@index([userId, status])
  @@index([userId, lane])
  @@index([userId, provider])
  @@index([createdAt])
}

model RevenueSignalImportJob {
  id                String                         @id @default(cuid())
  userId            String
  approvalId        String
  manifestId        String
  lane              String
  provider          String
  status            String                         @default("queued_review")
  transformTarget   String
  samplePayloadJson String?
  signalPreviewJson String
  externalExecution Boolean                        @default(false)
  providerContacted Boolean                        @default(false)
  auditLogId        String?
  handoffAuditLogId String?
  completedAt       DateTime?
  intakeResultJson  String?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  user              User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  approval          RevenueSignalConnectorApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  @@unique([userId, approvalId])
  @@index([userId, status])
  @@index([userId, lane])
  @@index([userId, provider])
  @@index([createdAt])
}

model Agent {
  id               String         @id @default(cuid())
  userId           String
  name             String
  role             String
  capabilitiesJson String
  webhookUrl       String?
  status           String         @default("idle")
  isPaused         Boolean        @default(false)
  runInBackground  Boolean        @default(true)
  lastActivitySeenAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks            AgentTask[]
  logs             AgentLog[]
  messages         AgentMessage[]
  schedules        AgentSchedule[]

  @@index([userId, status])
}

model AgentTask {
  id          String         @id @default(cuid())
  userId      String
  agentId     String
  title       String
  action      String
  status      String         @default("queued")
  payloadJson String
  resultJson  String?
  error       String?
  scheduleId  String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  logs        AgentLog[]
  messages    AgentMessage[]
  schedule    AgentSchedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([agentId, status])
  @@index([scheduleId])
}

model AgentSchedule {
  id              String      @id @default(cuid())
  userId          String
  agentId         String
  title           String
  action          String
  payloadJson     String
  status          String      @default("active")
  intervalMinutes Int
  nextRunAt       DateTime
  lastRunAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent           Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tasks           AgentTask[]

  @@index([userId, status])
  @@index([agentId, status])
  @@index([status, nextRunAt])
}

model Policy {
  id          String    @id @default(cuid())
  name        String
  description String?
  enabled     Boolean   @default(true)
  effect      String    @default("block")
  severity    String    @default("medium")
  ruleJson    String
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User?     @relation("PolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([enabled, severity])
}

model AuditLog {
  id          String    @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  outcome     String
  severity    String    @default("info")
  entryJson   String
  entryHash   String
  createdAt   DateTime  @default(now())
  actor       User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model CommandOSSnapshot {
  id           String   @id @default(cuid())
  userId       String   @unique
  stateVersion Int      @default(1)
  stateJson    String
  source       String   @default("dashboard")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model CommandOSReport {
  id                    String   @id @default(cuid())
  userId                String
  reportId              String
  sourceEntityId        String
  sourceEntityType      String
  destinationEntityId   String
  destinationEntityType String
  marshalId             String?
  generalId             String?
  commanderId           String?
  soldierId             String?
  situation             String
  analysis              String
  recommendation        String
  nextActionsJson       String
  reportCreatedAt       DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@index([userId, reportCreatedAt])
  @@index([marshalId])
  @@index([generalId])
  @@index([sourceEntityId])
}

model AgentLog {
  id        String     @id @default(cuid())
  agentId   String
  taskId    String?
  level     String     @default("info")
  message   String
  createdAt DateTime   @default(now())
  agent     Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task      AgentTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([agentId, createdAt])
  @@index([taskId, createdAt])
}

model AgentMessage {
  id          String     @id @default(cuid())
  agentId     String
  taskId      String?
  type        String
  action      String
  payloadJson String
  createdAt   DateTime   @default(now())
  agent       Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task        AgentTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([agentId, createdAt])
  @@index([taskId, createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AiUsageEvent {
  id                 String   @id @default(cuid())
  userId             String
  requestKind        String
  providerName       String
  modelName          String
  estimatedCostCents Int
  usedLocalFallback  Boolean  @default(false)
  requestId          String?
  metadataJson       String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, requestKind, createdAt])
  @@index([requestId])
}

model AutomationJob {
  id          String          @id @default(cuid())
  userId      String
  type        String
  status      String          @default("pending")
  payloadJson String
  resultJson  String?
  error       String?
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        AutomationLog[]

  @@index([userId, createdAt])
  @@index([status, scheduledAt])
}

model AutomationLog {
  id        String        @id @default(cuid())
  jobId     String
  level     String        @default("info")
  message   String
  createdAt DateTime      @default(now())
  job       AutomationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model Team {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   TeamMember[]
  tasks     Task[]
}

model TeamMember {
  userId   String
  teamId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@index([teamId])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       String     @default("TODO")
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  teamId       String
  createdById  String
  assignedToId String?
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy    User       @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo   User?      @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([createdById])
  @@index([assignedToId])
}
