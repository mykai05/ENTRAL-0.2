generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         String       @default("USER")
  emailVerifiedAt DateTime?
  lastDashboardSeenAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  TeamMember[]
  tasksCreated Task[]       @relation("TaskCreatedBy")
  tasksAssigned Task[]      @relation("TaskAssignedTo")
  conversations Conversation[]
  aiUsageEvents AiUsageEvent[]
  automationJobs AutomationJob[]
  agents      Agent[]
  agentTasks  AgentTask[]
  agentSchedules AgentSchedule[]
  merchStores ClientMerchStore[]
  commandSnapshot CommandOSSnapshot?
  commandReports CommandOSReport[]
  policiesCreated Policy[]      @relation("PolicyCreatedBy")
  auditLogs   AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  growthApprovalPackets GrowthApprovalPacket[] @relation("GrowthApprovalOwner")
  growthApprovalsReviewed GrowthApprovalPacket[] @relation("GrowthApprovalReviewer")

  @@index([email])
  @@index([emailVerifiedAt])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

enum MerchStorePlatform {
  ETSY    @map("Etsy")
  SHOPIFY @map("Shopify")
  OTHER   @map("Other")
}

enum MerchPodProvider {
  PRINTIFY @map("Printify")
  PRINTFUL @map("Printful")
  OTHER    @map("Other")
}

enum MerchApprovalStatus {
  NOT_STARTED       @map("Not Started")
  RESEARCH_APPROVED @map("Research Approved")
  DESIGNS_PENDING   @map("Designs Pending")
  DESIGNS_APPROVED  @map("Designs Approved")
  LISTINGS_APPROVED @map("Listings Approved")
  LAUNCH_APPROVED   @map("Launch Approved")
}

enum MerchLaunchStatus {
  LEAD              @map("Lead")
  DISCOVERY         @map("Discovery")
  RESEARCHING       @map("Researching")
  DESIGNING         @map("Designing")
  AWAITING_APPROVAL @map("Awaiting Approval")
  BUILDING_STORE    @map("Building Store")
  LAUNCHED          @map("Launched")
  OPTIMIZING        @map("Optimizing")
  PAUSED            @map("Paused")
  ARCHIVED          @map("Archived")
}

model ClientMerchStore {
  id              String               @id @default(cuid())
  userId          String
  clientName      String
  businessName    String
  contactName     String
  email           String
  phone           String?
  industry        String
  audience        String
  brandStyle      String
  storePlatform   MerchStorePlatform   @default(ETSY)
  podProvider     MerchPodProvider     @default(PRINTIFY)
  productTypes    String[]             @default([])
  designCount     Int                  @default(0)
  setupFee        Decimal              @default(0) @db.Decimal(12, 2)
  monthlyFee      Decimal              @default(0) @db.Decimal(12, 2)
  profitShare     Decimal              @default(0) @db.Decimal(5, 2)
  approvalStatus  MerchApprovalStatus  @default(NOT_STARTED)
  launchStatus    MerchLaunchStatus    @default(LEAD)
  revenue         Decimal              @default(0) @db.Decimal(12, 2)
  estimatedProfit Decimal              @default(0) @db.Decimal(12, 2)
  notes           String?
  commandMarshalId   String?
  commandMarshalName String?
  commandGeneralId   String?
  commandGeneralName String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  products        PodProduct[]
  growthApprovalPackets GrowthApprovalPacket[]

  @@index([userId, launchStatus])
  @@index([userId, approvalStatus])
  @@index([userId, createdAt])
  @@index([userId, commandMarshalId])
  @@index([userId, commandGeneralId])
  @@index([email])
}

model GrowthApprovalPacket {
  id                String           @id @default(cuid())
  userId            String
  storeId           String
  status            String           @default("pending")
  mode              String           @default("Mock Mode")
  packetJson        String
  scheduledFor      DateTime?
  requestAuditLogId String?
  reviewAuditLogId  String?
  reviewedAt        DateTime?
  reviewedById      String?
  reviewNote        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation("GrowthApprovalOwner", fields: [userId], references: [id], onDelete: Cascade)
  store             ClientMerchStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reviewedBy        User?            @relation("GrowthApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([storeId, status])
  @@index([scheduledFor])
  @@index([createdAt])
}

enum PodProductStatus {
  IDEA              @map("Idea")
  PROMPT_READY      @map("Prompt Ready")
  DESIGNED          @map("Designed")
  MOCKUP_CREATED    @map("Mockup Created")
  LISTING_DRAFTED   @map("Listing Drafted")
  COMPLIANCE_REVIEW @map("Compliance Review")
  AWAITING_APPROVAL @map("Awaiting Approval")
  APPROVED          @map("Approved")
  PUBLISHED         @map("Published")
  NEEDS_REVISION    @map("Needs Revision")
  REJECTED          @map("Rejected")
  ARCHIVED          @map("Archived")
}

model PodProduct {
  id                                  String           @id @default(cuid())
  storeId                             String
  productName                         String
  productType                         String
  targetAudience                      String
  designTheme                         String
  designConcept                       String
  designPrompt                        String
  typographyDirection                 String
  colorDirection                      String
  mockupNotes                         String?
  supplierCost                        Decimal          @default(0) @db.Decimal(12, 2)
  shippingCost                        Decimal          @default(0) @db.Decimal(12, 2)
  retailPrice                         Decimal          @default(0) @db.Decimal(12, 2)
  estimatedPlatformFees               Decimal          @default(0) @db.Decimal(12, 2)
  estimatedProfit                     Decimal          @default(0) @db.Decimal(12, 2)
  profitMargin                        Decimal          @default(0) @db.Decimal(7, 2)
  listingTitle                        String?
  listingDescription                  String?
  tags                                String[]         @default([])
  complianceNotes                     String?
  aiDisclosureNeeded                  Boolean          @default(false)
  productionPartnerDisclosureNeeded   Boolean          @default(false)
  status                              PodProductStatus @default(IDEA)
  commandMarshalId                    String?
  commandMarshalName                  String?
  commandGeneralId                    String?
  commandGeneralName                  String?
  commandCommanderId                  String?
  commandCommanderName                String?
  commandSoldierId                    String?
  commandSoldierName                  String?
  createdAt                           DateTime         @default(now())
  updatedAt                           DateTime         @updatedAt
  store                               ClientMerchStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([storeId, createdAt])
  @@index([commandMarshalId])
  @@index([commandGeneralId])
  @@index([productType])
}

model Agent {
  id               String         @id @default(cuid())
  userId           String
  name             String
  role             String
  capabilitiesJson String
  webhookUrl       String?
  status           String         @default("idle")
  isPaused         Boolean        @default(false)
  runInBackground  Boolean        @default(true)
  lastActivitySeenAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks            AgentTask[]
  logs             AgentLog[]
  messages         AgentMessage[]
  schedules        AgentSchedule[]

  @@index([userId, status])
}

model AgentTask {
  id          String         @id @default(cuid())
  userId      String
  agentId     String
  title       String
  action      String
  status      String         @default("queued")
  payloadJson String
  resultJson  String?
  error       String?
  scheduleId  String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  logs        AgentLog[]
  messages    AgentMessage[]
  schedule    AgentSchedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([agentId, status])
  @@index([scheduleId])
}

model AgentSchedule {
  id              String      @id @default(cuid())
  userId          String
  agentId         String
  title           String
  action          String
  payloadJson     String
  status          String      @default("active")
  intervalMinutes Int
  nextRunAt       DateTime
  lastRunAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent           Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tasks           AgentTask[]

  @@index([userId, status])
  @@index([agentId, status])
  @@index([status, nextRunAt])
}

model Policy {
  id          String    @id @default(cuid())
  name        String
  description String?
  enabled     Boolean   @default(true)
  effect      String    @default("block")
  severity    String    @default("medium")
  ruleJson    String
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User?     @relation("PolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([enabled, severity])
}

model AuditLog {
  id          String    @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  outcome     String
  severity    String    @default("info")
  entryJson   String
  entryHash   String
  createdAt   DateTime  @default(now())
  actor       User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model CommandOSSnapshot {
  id           String   @id @default(cuid())
  userId       String   @unique
  stateVersion Int      @default(1)
  stateJson    String
  source       String   @default("dashboard")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model CommandOSReport {
  id                    String   @id @default(cuid())
  userId                String
  reportId              String
  sourceEntityId        String
  sourceEntityType      String
  destinationEntityId   String
  destinationEntityType String
  marshalId             String?
  generalId             String?
  commanderId           String?
  soldierId             String?
  situation             String
  analysis              String
  recommendation        String
  nextActionsJson       String
  reportCreatedAt       DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@index([userId, reportCreatedAt])
  @@index([marshalId])
  @@index([generalId])
  @@index([sourceEntityId])
}

model AgentLog {
  id        String     @id @default(cuid())
  agentId   String
  taskId    String?
  level     String     @default("info")
  message   String
  createdAt DateTime   @default(now())
  agent     Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task      AgentTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([agentId, createdAt])
  @@index([taskId, createdAt])
}

model AgentMessage {
  id          String     @id @default(cuid())
  agentId     String
  taskId      String?
  type        String
  action      String
  payloadJson String
  createdAt   DateTime   @default(now())
  agent       Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task        AgentTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([agentId, createdAt])
  @@index([taskId, createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AiUsageEvent {
  id                 String   @id @default(cuid())
  userId             String
  requestKind        String
  providerName       String
  modelName          String
  estimatedCostCents Int
  usedLocalFallback  Boolean  @default(false)
  requestId          String?
  metadataJson       String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, requestKind, createdAt])
  @@index([requestId])
}

model AutomationJob {
  id          String          @id @default(cuid())
  userId      String
  type        String
  status      String          @default("pending")
  payloadJson String
  resultJson  String?
  error       String?
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        AutomationLog[]

  @@index([userId, createdAt])
  @@index([status, scheduledAt])
}

model AutomationLog {
  id        String        @id @default(cuid())
  jobId     String
  level     String        @default("info")
  message   String
  createdAt DateTime      @default(now())
  job       AutomationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model Team {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   TeamMember[]
  tasks     Task[]
}

model TeamMember {
  userId   String
  teamId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@index([teamId])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       String     @default("TODO")
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  teamId       String
  createdById  String
  assignedToId String?
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy    User       @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo   User?      @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([createdById])
  @@index([assignedToId])
}
