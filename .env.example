# Shared
NODE_ENV=development
DATABASE_URL="postgresql://entral:entral_password@localhost:5432/entral?schema=public"

# Backend
API_HOST="0.0.0.0"
API_PORT=4000
JWT_SECRET="replace-with-a-long-random-secret"
COOKIE_NAME="entral_token"
CORS_ORIGIN="http://localhost:3000"
APP_PUBLIC_URL="http://localhost:3000"
API_PUBLIC_URL="http://localhost:4000"
REDIS_URL="redis://localhost:6379"
LOG_LEVEL="info"
# Use console for local development. Production must use "resend" with the fields below configured.
AUTH_EMAIL_PROVIDER="console"
AUTH_EMAIL_FROM="ENTRAL <security@your-domain.com>"
RESEND_API_KEY=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
GITHUB_TOKEN=""
GITHUB_OWNER=""
GITHUB_REPO=""
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
SHOPIFY_STORE_DOMAIN=""
SHOPIFY_CONNECTOR_ADMIN_TOKEN=""
SHOPIFY_API_VERSION="2026-04"
SHOPIFY_APP_API_KEY=""
SHOPIFY_APP_API_SECRET=""
SHOPIFY_APP_SCOPES="read_products,write_products,read_online_store_pages,write_online_store_pages,read_online_store_navigation,write_online_store_navigation"
# Optional Playwright storage state exported after the owner signs into Shopify Dev Dashboard once.
SHOPIFY_DEV_DASHBOARD_STORAGE_STATE_PATH=""
AI_FEATURE_ENABLED=true
AI_LOCAL_FALLBACK=true
AI_DAILY_COST_LIMIT_CENTS=250
AI_MONTHLY_COST_LIMIT_CENTS=2500
AI_DECISION_ESTIMATED_COST_CENTS=1
AI_CHAT_ESTIMATED_COST_CENTS=4
AI_SCREEN_ESTIMATED_COST_CENTS=8
AI_LOCAL_FALLBACK_ESTIMATED_COST_CENTS=0
AUTOMATION_FEATURE_ENABLED=true
AUTOMATION_WORKER_ENABLED=true
AUTOMATION_ALLOWED_DOMAINS="example.com"
AUTOMATION_LOCAL_FALLBACK=true
AUTOMATION_MAX_CONCURRENCY=2
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=""
AGENT_ORCHESTRATOR_ENABLED=true
AGENT_MAX_CONCURRENCY=3
AUTONOMY_SCHEDULER_ENABLED=true
AUTONOMY_SCHEDULER_INTERVAL_MS=5000
AUTONOMY_MIN_INTERVAL_MINUTES=15
DATA_ENCRYPTION_KEY=""
ADMIN_MFA_CODE=""
ALERT_WEBHOOK_URL=""

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Production frontend only: set this to your deployed backend URL and set NEXT_PUBLIC_API_URL="" to proxy API calls through the frontend domain.
API_PROXY_URL=""
